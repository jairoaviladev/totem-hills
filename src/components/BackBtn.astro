---
interface Props {
  label?: string;
}
const { label = "← Volver" } = Astro.props;
---
<div class="w-full px-10 pt-8 ">
  <button
    onclick="history.back()"
    class="text-[#013173] cursor-pointer font-bold text-2xl active:opacity-60 flex items-center gap-2  hover:gap-4 transition-all"
  >
    {label}
  </button>
</div>