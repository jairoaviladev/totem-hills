---
/**
 * Componente Footer 
 */
---

<!-- Curva superior del footer — el fill coincide con el bg del footer -->
<div class="w-full overflow-hidden leading-none">
  <svg
    viewBox="0 0 1000 80"
    preserveAspectRatio="none"
    class="w-full h-16 block"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path d="M0,0 C250,80 750,80 1000,0 L1000,80 L0,80 Z" fill="#013173"
    ></path>
  </svg>
</div>

<!-- Contenido del footer -->
<div class="text-center w-full bg-[#013173] pt-4 pb-8 px-6">
  <div class="text-blue-500 text-3xl mb-3">❤️</div>
  <p class="text-white text-2xl font-bold tracking-widest uppercase mb-2">
    La ciencia lo hace por ti.
  </p>
  <span class="text-slate-300 text-xs font-mono block">
    ©2026 Hill's Pet Nutrition, Inc.
  </span>
  <span class="text-slate-400 text-xs font-mono block mt-1">
    ™ Marcas registradas propiedad de Hill's Pet Nutrition, Inc.
  </span>
</div>