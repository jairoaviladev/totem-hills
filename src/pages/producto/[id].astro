---
import LayoutBase from "../../layouts/LayoutBase.astro";
import ContenedorTotem from "../../components/ContenedorTotem.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BackBtn from "../../components/BackBtn.astro";
import { productosData } from "../../data/productos";


export function getStaticPaths() {
  return Object.keys(productosData).map((id) => ({
    params: { id },
  }));
}

const { id } = Astro.params;
const p = productosData[id as string];

if (!p) return Astro.redirect("/");
---

<LayoutBase title={`Hill's | ${p.nombre}`}>
  <ContenedorTotem>
    <div class="flex flex-col h-full overflow-y-auto bg-[#dfecfc]">
      <Header />
      <BackBtn label="← Volver a sistemas" />

      <div class="flex-1 px-10 py-6 grid grid-cols-2 gap-6 content-center">
        <div class="flex flex-col gap-4">
          <div class="flex items-center gap-4">
            <div
              class="w-16 h-16 rounded-full bg-[#013173] flex items-center justify-center flex-shrink-0 shadow-md"
            >
              <span id="punto-id" class="text-white text-2xl font-black">.</span
              >
            </div>
            <h1
              id="sistema-nombre"
              class="text-[#013173] text-4xl font-black leading-tight"
            >
              {p.nombre}
            </h1>
          </div>

          <hr class="border-slate-300" />

          <div>
            <p class="text-slate-500 text-2xl">Producto recomendado:</p>
            <h2 class="text-[#F9A11F] text-5xl font-black">{p.nombre}</h2>
            <p class="text-slate-500 text-2xl mt-1">{p.subtitulo}</p>
          </div>

          <p class="text-slate-700 text-xl leading-relaxed font-semibold">
            {p.descripcion}
          </p>
             <!-- Beneficios -->
          <div class="bg-[#013173]/80 rounded-3xl p-6 shadow-sm">
            <h3 class="text-white text-2xl font-black mb-4">
              Beneficios clave
            </h3>
            <div class="flex flex-col gap-4">
              {
                p.beneficios.map((b) => (
                  <div class="flex items-center gap-4">
                    <img
                      src={b.icono.src}
                      alt={b.texto}
                      width={50}
                      height={50}
                      class="object-contain shrink-0"
                    />
                    <p class="text-white text-lg leading-snug">{b.texto}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- COL 2: Imagen del producto -->
        <div
          class="flex items-center justify-center rounded-3xl overflow-hidden h-[800px]"
        >
          <img
            src={p.imagen}
            alt={p.nombre}
            loading="lazy"
            class="h-full w-full object-cover"
          />
        </div>

        <!-- FILA 2: Dato clínico -->
        <div
          class="col-span-2 bg-white/50 rounded-3xl p-8 shadow-sm flex items-center gap-8"
        >
          <span class="text-5xl flex-shrink-0">{p.datoClinico.icono}</span>
          <div class="flex-1">
            <p class="text-[#013173] font-black text-xl">
              {p.datoClinico.titulo}
            </p>
            <p class="text-slate-600 text-lg mt-1">
              {p.datoClinico.descripcion}
            </p>
          </div>
          <div
            class={`w-45 h-45 flex flex-col align-middle justify-center text-center flex-shrink-0  rounded-full ${p.datoClinico.bgColor} px-8 py-5`}
          >
            <div class="text-white text-5xl font-black">
              {p.datoClinico.badge.valor}
            </div>
            <div class="text-blue-200 text-3xl">
              {p.datoClinico.badge.unidad}
            </div>
          </div>
        </div>

        <!-- FILA 3: Advertencia -->
        <div
          class="col-span-2 bg-white/50 rounded-3xl p-6 shadow-sm flex items-start gap-4"
        >
          <span class="text-3xl flex-shrink-0">ℹ️</span>
          <p class="text-slate-500 text-lg leading-relaxed">{p.advertencia}</p>
        </div>
      </div>
      <Footer />
    </div>
  </ContenedorTotem>
</LayoutBase>

<script is:inline>
  /**
   * Lee query params en el cliente.
   * Verifica readyState para cubrir el caso en que DOMContentLoaded
   * ya se disparó antes de que el script inline se ejecute.
   */
  function hidratarParams() {
    const params = new URLSearchParams(window.location.search);
    const puntoId = params.get("punto");
    const sistemaNombre = params.get("sistema");

    if (puntoId) {
      const el = document.getElementById("punto-id");
      if (el) el.textContent = puntoId;
    }

    if (sistemaNombre) {
      const el = document.getElementById("sistema-nombre");
      if (el) el.textContent = decodeURIComponent(sistemaNombre);
    }
  }

  /**
   * Si el DOM ya está listo, ejecuta inmediatamente.
   * Si no, espera al evento DOMContentLoaded.
   */
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", hidratarParams);
  } else {
    hidratarParams();
  }
</script>
